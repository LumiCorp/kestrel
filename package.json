{
  "name": "kestrel",
  "version": "0.5.1",
  "description": "Minimal durable runtime kernel for agentic step execution",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist/src",
    "dist/agents",
    "dist/models",
    "dist/tools",
    "dist/cli",
    "bin",
    "cli",
    "src",
    "!src/**/__pycache__/**",
    "!src/**/*.pyc",
    "agents",
    "models",
    "tools",
    "db/migrations",
    "scripts/start.ts",
    "scripts/migrate.ts",
    "scripts/migrate-v2-to-v3.ts",
    "scripts/install-cli.sh",
    "tsconfig.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node --import tsx scripts/start.ts",
    "demo:apps": "node --import tsx scripts/demo-apps.ts",
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true });\"",
    "build": "pnpm run sdk:build && pnpm run clean && tsc -p tsconfig.json",
    "tui:build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm run test:core && pnpm run web:test && pnpm run desktop:test && pnpm run evals:validate && pnpm run docs:test && pnpm run protocol:test && pnpm run sdk:test && pnpm run next:test && pnpm run observability:test",
    "test:core": "pnpm run protocol:build && KESTREL_LOCAL_CORE_DIRECT=1 node --import tsx --test tests/**/*.test.ts agents/**/*.test.ts",
    "web:prepare": "pnpm run sdk:build && pnpm run next:build",
    "web:dev": "pnpm run web:prepare && pnpm --filter @kestrel/kestrel-one dev",
    "web:build": "pnpm run web:prepare && pnpm --filter @kestrel/kestrel-one build",
    "web:start": "pnpm --filter @kestrel/kestrel-one start",
    "web:test": "pnpm run web:prepare && pnpm --filter @kestrel/kestrel-one test",
    "web:typecheck": "pnpm run web:prepare && pnpm --filter @kestrel/kestrel-one typecheck",
    "docs:dev": "WATCHPACK_POLLING=true pnpm --filter @kestrel/docs dev",
    "docs:build": "pnpm --filter @kestrel/docs build",
    "docs:start": "pnpm --filter @kestrel/docs start",
    "docs:test": "pnpm --filter @kestrel/docs test",
    "protocol:build": "pnpm --filter @kestrel-agents/protocol build",
    "protocol:test": "pnpm --filter @kestrel-agents/protocol test",
    "protocol:release-check": "pnpm --filter @kestrel-agents/protocol release:check",
    "sdk:build": "pnpm --filter @kestrel-agents/sdk build",
    "sdk:test": "pnpm --filter @kestrel-agents/sdk test",
    "sdk:smoke": "pnpm --filter @kestrel-agents/sdk smoke:import",
    "sdk:release-check": "pnpm --filter @kestrel-agents/sdk release:check",
    "observability:build": "pnpm --filter @kestrel-agents/observability build",
    "observability:test": "pnpm --filter @kestrel-agents/observability test",
    "observability:smoke": "pnpm --filter @kestrel-agents/observability smoke:import",
    "observability:release-check": "pnpm --filter @kestrel-agents/observability release:check",
    "next:build": "pnpm --filter @kestrel-agents/next build",
    "next:test": "pnpm --filter @kestrel-agents/next test",
    "next:smoke": "pnpm --filter @kestrel-agents/next smoke:import",
    "next:release-check": "pnpm --filter @kestrel-agents/next release:check",
    "ecosystem:e2e": "pnpm run sdk:build && pnpm run observability:build && pnpm run next:build && node --import tsx --test tests/e2e/sdk-ecosystem/ecosystem.test.ts tests/e2e/sdk-ecosystem/realtime-faults.test.ts",
    "ecosystem:otel-e2e": "pnpm run otel:up && pnpm run sdk:build && pnpm run observability:build && node --import tsx --test tests/e2e/sdk-ecosystem/otel-collector.test.ts",
    "ecosystem:next-fixture": "pnpm run sdk:build && pnpm run next:build && node --import tsx --test tests/e2e/sdk-ecosystem/next-fixture.test.ts",
    "ecosystem:release-check": "pnpm run protocol:release-check && pnpm run sdk:release-check && pnpm run observability:release-check && pnpm run next:release-check && pnpm run ecosystem:e2e && pnpm run ecosystem:otel-e2e && pnpm run ecosystem:next-fixture",
    "desktop:dev": "pnpm --filter @kestrel/desktop dev",
    "desktop:build": "pnpm --filter @kestrel/desktop build",
    "desktop:package": "pnpm --filter @kestrel/desktop package",
    "desktop:postgres-smoke": "node --import tsx scripts/desktop-postgres-package-smoke.ts",
    "desktop:package-smoke": "pnpm run desktop:postgres-smoke && node --import tsx scripts/desktop-package-smoke.ts",
    "desktop:release-check": "node --import tsx scripts/check-desktop-release.ts",
    "desktop:test": "pnpm --filter @kestrel/desktop test",
    "prompt-suite": "node --import tsx scripts/prompt-suite.ts",
    "check:docs": "node --import tsx scripts/check-docs.ts",
    "check:agents": "node --import tsx scripts/check-agents.ts",
    "check:architecture": "node --import tsx scripts/check-architecture.ts",
    "check:public-boundary": "node --import tsx scripts/check-public-boundary.ts",
    "check:invariants": "node --import tsx scripts/check-invariants.ts",
    "check:desktop-resources": "node --import tsx scripts/check-desktop-resources.ts",
    "check:evals": "node --import tsx scripts/validate-ruhroh-evals.ts",
    "check:replay-baseline": "node --import tsx scripts/check-replay-baseline.ts",
    "check:release-tracks": "node --import tsx scripts/check-release-tracks.ts",
    "cli:contract-matrix": "node --import tsx scripts/generate-cli-contract-matrix.ts",
    "cli:package": "node --import tsx scripts/package-cli.ts",
    "cli:release-check": "node --import tsx scripts/check-cli-release.ts",
    "local-core:release-smoke": "node --import tsx scripts/local-core-release-smoke.ts",
    "replay:seed": "node --import tsx scripts/seed-replay-suite.ts",
    "docs:drift": "node --import tsx scripts/scan-doc-drift.ts",
    "scorecard:generate": "node --import tsx scripts/generate-quality-scorecard.ts",
    "gates:classify": "node --import tsx scripts/classify-gates.ts",
    "governance:check": "pnpm run check:agents && pnpm run check:docs && pnpm run check:architecture && pnpm run check:public-boundary && pnpm run check:invariants && pnpm run check:desktop-resources && pnpm run check:evals && pnpm run check:release-tracks && pnpm run check:replay-baseline",
    "evals:validate": "node --import tsx scripts/validate-ruhroh-evals.ts",
    "evals:release-check": "pnpm run evals:validate",
    "runtime:graph": "node --import tsx cli/runtime.ts graph",
    "runtime:replay": "node --import tsx cli/runtime.ts replay",
    "runtime:doctor": "node --import tsx cli/runtime.ts doctor",
    "runtime:bundle": "node --import tsx cli/runtime.ts bundle",
    "runtime:cleanup-shells": "node --import tsx cli/runtime.ts cleanup-shells",
    "runtime:release-check": "pnpm run build && node --import tsx scripts/check-runtime-package.ts",
    "runtime:inspect-corrupted-next-actions": "node --import tsx scripts/inspect-corrupted-next-actions.ts",
    "bench:smoke": "node --import tsx scripts/benchmark-smoke.ts",
    "bench:terminal": "node --import tsx scripts/terminal-bench.ts",
    "bench:terminal:harbor": "node --import tsx scripts/terminal-bench-harbor.ts",
    "bench:terminal:codex": "node --import tsx scripts/terminal-bench-codex.ts",
    "bench:terminal:sentinel": "node --import tsx scripts/terminal-bench-sentinel.ts",
    "bench:swe": "bash scripts/bench-swe.sh",
    "tb": "bash scripts/tb.sh",
    "tb2": "bash scripts/tb2.sh",
    "tb2-codex": "bash scripts/tb2-codex.sh",
    "tb2-passing": "bash scripts/tb2-passing.sh",
    "tb2-medium-low": "bash scripts/tb2-medium-low.sh",
    "swe": "bash scripts/swe.sh",
    "swe:passing": "bash scripts/swe-passing.sh",
    "swe:medium-low": "bash scripts/swe-medium-low.sh",
    "runner:service": "node --import tsx cli/runner/service.ts",
    "test:runner-service": "node --import tsx scripts/test-runner-service.ts",
    "test:web-runner": "node --import tsx scripts/test-web-runner.ts",
    "test:web-runner:live": "node --import tsx scripts/test-web-runner-live.ts",
    "test:ops:web": "playwright test -c tests/ops/web/playwright.config.ts",
    "test:ops:cli": "node --import tsx --test tests/ops/cli/**/*.ops.ts",
    "test:ops:tui": "node --import tsx --test tests/ops/tui/**/*.ops.ts",
    "test:ops": "pnpm run test:ops:cli && pnpm run test:ops:tui && pnpm run test:ops:web",
    "live:test:product": "node --import tsx scripts/live-product-e2e.ts",
    "live:code-mode:e2e": "node --import tsx scripts/live-code-mode-e2e.ts",
    "mountaintop:list": "node --import tsx scripts/mountaintop-e2e.ts --list",
    "mountaintop:run": "node --import tsx scripts/mountaintop-e2e.ts",
    "mountaintop:cli": "node --import tsx scripts/mountaintop-e2e.ts --engine cli",
    "mountaintop:scaffold": "node --import tsx scripts/mountaintop-e2e.ts --scenario nextjs-template-scaffold-smoke --engine cli --auto-db",
    "mountaintop:scaffold:real-user": "node --import tsx scripts/mountaintop-e2e.ts --scenario nextjs-template-scaffold-real-user-cli --engine cli --auto-db",
    "mountaintop:newsletter:research": "node --import tsx scripts/mountaintop-e2e.ts --scenario nextjs-template-newsletter-research-real-user-cli --engine cli --auto-db",
    "mountaintop:newsletter": "node --import tsx scripts/mountaintop-e2e.ts --scenario nextjs-template-newsletter-real-user-cli --engine cli --auto-db",
    "mountaintop:todo:real-user": "node --import tsx scripts/mountaintop-e2e.ts --scenario nextjs-template-todo-auth-real-user-cli --engine cli --auto-db",
    "bench:handoff": "node --import tsx scripts/handoff-benchmark.ts",
    "trust:demos": "node --import tsx scripts/trust-demos.ts",
    "tui": "node --import tsx cli/tui.ts",
    "tui:smoke": "node --import tsx scripts/kchat-smoke.ts",
    "cli:prompt-smoke": "node --import tsx scripts/cli-prompt-smoke.ts",
    "install:cli": "bash scripts/install-cli.sh",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d postgres",
    "otel:up": "docker compose up -d jaeger",
    "otel:down": "docker compose stop jaeger",
    "stack:up": "docker compose up -d postgres jaeger",
    "stack:down": "docker compose down",
    "db:migrate": "node --import tsx scripts/migrate.ts",
    "db:migrate:v3": "node --import tsx scripts/migrate-v2-to-v3.ts"
  },
  "bin": {
    "kestrel": "bin/kestrel.js",
    "ks": "bin/kestrel.js",
    "kcron": "bin/kcron.js"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LumiCorp/kestrel.git"
  },
  "homepage": "https://github.com/LumiCorp/kestrel",
  "bugs": {
    "url": "https://github.com/LumiCorp/kestrel/issues"
  },
  "keywords": [
    "runtime",
    "agent",
    "workflow",
    "durable"
  ],
  "license": "MIT",
  "devDependencies": {
    "@kestrel-agents/ruhroh": "0.6.0-beta.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.205.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.13.10",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.14",
    "typescript": "^5.8.2"
  },
  "packageManager": "pnpm@9.12.2+sha512.22721b3a11f81661ae1ec68ce1a7b879425a1ca5b991c975b074ac220b187ce56c708fe5db69f4c962c989452eee76c82877f4ee80f474cebd61ee13461b6228",
  "dependencies": {
    "@electric-sql/pglite": "^0.4.2",
    "@kestrel-agents/protocol": "0.5.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@tavily/core": "^0.7.2",
    "ajv": "^8.18.0",
    "cron-parser": "^5.5.0",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "pg": "^8.18.0",
    "react": "^19.2.4",
    "tsx": "^4.19.3"
  }
}

{
  "name": "@kestrel-agents/workspace-skills",
  "version": "0.6.0",
  "description": "Secure workspace-scoped SKILL.md installation and provenance for Kestrel agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LumiCorp/kestrel.git",
    "directory": "packages/workspace-skills"
  },
  "homepage": "https://github.com/LumiCorp/kestrel/tree/main/packages/workspace-skills",
  "bugs": {
    "url": "https://github.com/LumiCorp/kestrel/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm run build:self",
    "build:self": "pnpm run clean && tsc -p tsconfig.json",
    "clean": "node --input-type=module -e \"import { rmSync } from 'node:fs'; rmSync('dist', { recursive: true, force: true });\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "yaml": "2.8.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2"
  }
}

{
  "name": "@lumi/kestrel-environment-auth",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm run build:self",
    "build:self": "tsc -p tsconfig.json",
    "test": "pnpm run test:unit",
    "test:unit": "node ../../scripts/validate.mjs --leaf hermetic packages/environment-auth",
    "typecheck": "pnpm run typecheck:self",
    "typecheck:self": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}

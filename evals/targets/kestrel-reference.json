{
  "$schema": "https://lumicorp.github.io/ruhroh/schemas/benchmark-target-config-v1.schema.json",
  "version": "ruhroh_benchmark_target_config_v1",
  "stream": "custom",
  "targets": [
    {
      "targetId": "kestrel-reference-local",
      "adapterId": "kestrel-cli",
      "harness": {
        "name": "kestrel",
        "version": "0.6.0-beta.0"
      },
      "requestedModel": {
        "provider": "kestrel-runtime-policy",
        "model": "configured-by-runtime-policy",
        "protocol": "kestrel-job-v1",
        "promptVersion": "kestrel-runtime-0.6"
      },
      "providerPath": {
        "provider": "kestrel-runtime-policy",
        "protocol": "kestrel-job-v1"
      },
      "recommendedStack": {
        "recommended": true,
        "rationale": "Uses Kestrel's public reference profile and Ruhroh's maintained Kestrel job-contract adapter."
      },
      "env": {
        "KESTREL_PROFILE_ID": "reference",
        "KESTREL_STORE_DRIVER": "auto",
        "KESTREL_CLI_ADAPTER_VERSION": "0.1.0"
      }
    }
  ]
}

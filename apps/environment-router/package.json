{
  "name": "@kestrel/environment-router",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @lumi/kestrel-environment-auth build && pnpm run build:self",
    "build:self": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "pnpm run test:unit",
    "test:unit": "node ../../scripts/validate.mjs --leaf hermetic apps/environment-router",
    "test:integration": "node ../../scripts/validate.mjs --leaf process apps/environment-router",
    "typecheck": "pnpm run typecheck:self",
    "typecheck:self": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@lumi/kestrel-environment-auth": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}

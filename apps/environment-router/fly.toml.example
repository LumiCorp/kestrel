# Image-development example only. Kestrel One provisions one gateway Machine
# inside each Environment App and supplies the Environment-specific settings.
app = "kestrel-environment-router-image"
primary_region = "iad"

[build]
  dockerfile = "apps/environment-router/Dockerfile"

[http_service]
  internal_port = 8080
  force_https = true
  auto_stop_machines = "off"
  auto_start_machines = true
  min_machines_running = 1

[[vm]]
  size = "shared-cpu-1x"
  memory = "512mb"

{
  "name": "@kestrel/workspace-runtime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @lumi/kestrel-environment-auth build && pnpm --filter @kestrel-agents/sdk build && pnpm --filter @kestrel-agents/workspace-skills build && pnpm run build:self",
    "build:self": "tsc -p tsconfig.json",
    "canary:local": "tsx scripts/local-canary.ts",
    "start": "node dist/server.js",
    "test": "pnpm run test:unit",
    "test:unit": "node ../../scripts/validate.mjs --leaf hermetic apps/workspace-runtime",
    "test:integration": "node ../../scripts/validate.mjs --leaf process apps/workspace-runtime",
    "typecheck": "pnpm run typecheck:self",
    "typecheck:self": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@kestrel-agents/sdk": "workspace:*",
    "@kestrel-agents/workspace-skills": "workspace:*",
    "@lumi/kestrel-environment-auth": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}

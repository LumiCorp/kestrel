{
  "name": "@kestrel/desktop",
  "private": true,
  "version": "0.6.0",
  "type": "module",
  "main": "dist/apps/desktop/src/main.js",
  "scripts": {
    "clean:dist": "rm -rf dist",
    "dev": "pnpm run clean:dist && pnpm run typecheck && pnpm run renderer:build && pnpm run prepare:resources && tsc -p tsconfig.json --noCheck && electron-forge start",
    "prepare:resources": "node --import tsx ../../scripts/prepare-desktop-resources.ts",
    "prepare:package-stage": "node --import tsx ../../scripts/prepare-desktop-package-stage.ts",
    "renderer:build": "vite build --config vite.config.ts",
    "renderer:dev": "vite --config vite.config.ts --host 127.0.0.1",
    "build": "pnpm run typecheck:self && pnpm run build:self",
    "build:self": "pnpm run clean:dist && pnpm run renderer:build && pnpm run prepare:resources && tsc -p tsconfig.json --noCheck",
    "package": "pnpm run build && pnpm run prepare:package-stage && node --import tsx ../../scripts/package-desktop.ts",
    "make": "pnpm run package",
    "typecheck": "pnpm run typecheck:self",
    "typecheck:self": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "test": "pnpm run test:unit",
    "test:unit": "node ../../scripts/validate.mjs --leaf hermetic apps/desktop",
    "test:integration": "node ../../scripts/validate.mjs --leaf process apps/desktop"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.9",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@tavily/core": "^0.7.2",
    "@xterm/xterm": "6.0.0",
    "ajv": "^8.18.0",
    "content-type": "^1.0.5",
    "cross-spawn": "^7.0.5",
    "electron-squirrel-startup": "^1.0.1",
    "eventsource-parser": "^3.0.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "hono": "^4.11.4",
    "ink": "^6.8.0",
    "ink-text-input": "^6.0.0",
    "jose": "^6.1.3",
    "json-schema-typed": "^8.0.2",
    "lucide-react": "^1.18.0",
    "pg": "^8.18.0",
    "pkce-challenge": "^5.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "streamdown": "^2.0.1",
    "tsx": "^4.19.3",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.1"
  },
  "overrides": {
    "postcss": "8.5.15"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.1",
    "@electron-forge/maker-zip": "^7.8.1",
    "@types/node": "^22.13.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "electron": "^37.2.6",
    "electron-packager": "^17.1.2",
    "typescript": "^5.8.2",
    "vite": "^7.3.2"
  }
}

{
  "name": "@kestrel/mcp-service",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @lumi/kestrel-environment-auth build && pnpm --filter @kestrel/mcp-security build && pnpm run build:self",
    "build:self": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "pnpm --filter @lumi/kestrel-environment-auth build && pnpm --filter @kestrel/mcp-security build && pnpm run test:self",
    "test:self": "node --import tsx --test tests/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@kestrel-agents/protocol": "workspace:*",
    "@kestrel/mcp-security": "workspace:*",
    "@lumi/kestrel-environment-auth": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "pg": "^8.20.0",
    "undici": "^6.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/pg": "^8.18.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}

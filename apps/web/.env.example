# Database
# Required: PostgreSQL connection string
# Examples:
#   Local: postgresql://postgres:postgres@127.0.0.1:58432/better_auth
#   Vercel: Use POSTGRES_URL (auto-set by Vercel Postgres)
LOCAL_POSTGRES_PORT=58432
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:58432/better_auth

# Optional: some scripts use POSTGRES_URL directly; keep it in sync with DATABASE_URL.
# POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:58432/better_auth

# Auth
# Required: secret used for session and auth signing (generate with: pnpm generate-secret)
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

# Required: Your app's URL
#   Local: http://127.0.0.1:43103
#   Production: https://your-app.vercel.app
BETTER_AUTH_URL=http://127.0.0.1:43103
NEXT_PUBLIC_APP_URL=http://127.0.0.1:43103

# Email Configuration (Optional)
# Only needed if you want email functionality (password reset, verification, invitations)
# Get your API key from: https://resend.com
# RESEND_API_KEY=re_your_resend_api_key
# BETTER_AUTH_EMAIL=noreply@yourdomain.com
# BETTER_AUTH_REPLY_TO=support@yourdomain.com
# Platform admins can keep these environment-managed or switch to an encrypted
# stored Resend key from Admin → Integrations → Email.

# Social Authentication Providers (Optional)
# Configure OAuth apps for these providers if you want social login.
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret

# Kestrel's product-level GitHub OAuth App. GitHub is link-only organizational
# tooling and is not a Kestrel sign-in provider. Request the repo scope in v1.
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret
# DISCORD_CLIENT_ID=your_discord_client_id
# DISCORD_CLIENT_SECRET=your_discord_client_secret
# APPLE_CLIENT_ID=your_apple_client_id
# APPLE_CLIENT_SECRET=your_apple_client_secret

# Stripe Integration (Optional)
# Set NEXT_PUBLIC_BILLING_ENABLED=true only when all Stripe vars below are configured.
# Billing is organization-owned: shared orgs manage plans from /dashboard/organizations,
# while /admin/billing is reserved for integration diagnostics.
NEXT_PUBLIC_BILLING_ENABLED=false
# STRIPE_KEY=sk_test_your_stripe_key
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
# STRIPE_PRO_ANNUAL_PRICE_ID=price_xxx
# STRIPE_PRO_PRICE_ID=price_xxx
# STRIPE_PLUS_ANNUAL_PRICE_ID=price_xxx
# STRIPE_PLUS_PRICE_ID=price_xxx

# Vercel Postgres (Auto-set by Vercel)
# POSTGRES_URL is automatically set when you create a Postgres database in Vercel
# Better Auth will use POSTGRES_URL if DATABASE_URL is not set
# POSTGRES_URL=postgres://...

# Optional: Redis for resumable chat streams and rate limit helpers.
LOCAL_REDIS_PORT=56379
# REDIS_URL=redis://127.0.0.1:56379

# Hosted Environment runtime. Kestrel One never targets a global runner.
KESTREL_ENVIRONMENTS_ENABLED=false
# Generate an Ed25519 key pair; Kestrel One receives the private key and the router/runtime receive only the public key.
# KESTREL_ENVIRONMENT_TICKET_PRIVATE_KEY=replace-with-ed25519-private-key-pem
# KESTREL_ENVIRONMENT_TICKET_PUBLIC_KEY=replace-with-ed25519-public-key-pem
# FLY_API_TOKEN=FlyV1...
# KESTREL_FLY_ORGANIZATION_SLUG=your-fly-organization
# KESTREL_ENVIRONMENT_ROUTER_IMAGE=registry.fly.io/kestrel-environment-router@sha256:...
# KESTREL_WORKSPACE_RUNTIME_IMAGE=registry.fly.io/kestrel-workspace@sha256:...
# KESTREL_WORKSPACE_BACKUP_KEY=base64-encoded-32-byte-key
# KESTREL_WORKSPACE_BACKUP_KEY_ID=workspace-backup-v1
KESTREL_ONE_PROFILE_ID=kestrel-one
KESTREL_ONE_TOOL_TOKEN=dev-secret
# Runner-to-Kestrel-One credential leases use a separate service credential.
KESTREL_ONE_APP_URL=http://127.0.0.1:43103
KESTREL_ONE_CREDENTIAL_BROKER_TOKEN=dev-credential-broker-secret
# Local-only AES-256-GCM keyring example. Generate a unique 32-byte key for every deployment.
KESTREL_GATEWAY_CREDENTIAL_ACTIVE_KEY_ID=local-v1
KESTREL_GATEWAY_CREDENTIAL_KEYS='{"local-v1":"AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA="}'
# Optional environment-backed credential for RunPod Serverless gateways.
# RUNPOD_API_KEY=your_runpod_api_key
# Keep false until the managed deployment migration is applied and the platform
# RunPod connection, first qualified profile, and organization quotas are ready.
RUNPOD_MANAGED_DEPLOYMENTS_ENABLED=false

# Optional GitHub bot/knowledge ingestion App credentials. These are unrelated
# to Environment repository access, which uses each member's linked OAuth identity.
# GITHUB_APP_ID=123456
# GITHUB_APP_SLUG=your-kestrel-app
# GITHUB_APP_PRIVATE_KEY=replace-with-github-app-private-key-pem

# Legacy local AI loop settings remain for migration-only surfaces.
# Use an OpenAI-compatible provider such as OpenAI or OpenRouter.
AI_PROVIDER=openrouter
AI_AGENT_API_KEY=sk_your_provider_key
AI_AGENT_BASE_URL=https://openrouter.ai/api/v1
AI_AGENT_MODEL=openai/gpt-5-mini

# Optional OpenRouter attribution headers.
# Keep these in sync with your deployed app URL/name.
# AI_AGENT_SITE_URL=http://127.0.0.1:43103
# AI_AGENT_SITE_NAME=Kestrel One

# Optional public metadata overrides.
# NEXT_PUBLIC_OG_IMAGE_URL=https://your-app.example.com/og.png

# Optional: embedding model override for knowledge document indexing.
# AI_EMBEDDING_MODEL=text-embedding-3-small

# Object Storage / Knowledge Uploads
# Defaults below work with the local Docker Compose MinIO service.
LOCAL_MINIO_API_PORT=59000
LOCAL_MINIO_CONSOLE_PORT=59001
STORAGE_PROVIDER=local-s3
STORAGE_BUCKET=unified-app-storage
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=http://127.0.0.1:59000
STORAGE_ACCESS_KEY_ID=minioadmin
STORAGE_SECRET_ACCESS_KEY=minioadmin
STORAGE_FORCE_PATH_STYLE=true
STORAGE_KEY_PREFIX=unified-app

# Optional: admin override list for knowledge/admin API guards.
# Comma-separated user IDs. Leave unset unless you intentionally want fixed admin identities.
# ADMIN_USER_IDS=user-id-1,user-id-2

# Optional: sandbox command execution base directory for knowledge sandbox APIs.
# SANDBOX_BASE_DIR=/absolute/path/to/workspace

# Optional: preseed a local-only dev admin for automated runs.
# `pnpm create-dev-admin` uses these values. Do not reuse these in shared or production environments.
DEV_ADMIN_EMAIL=admin@dev.local
DEV_ADMIN_PASSWORD=devpass123
DEV_ADMIN_NAME="Dev Admin"
DEV_ORG_NAME="Dev-org"

# Optional: localhost-only browser auto-login for `pnpm dev:all`.
# This is ignored for non-local hosts and does not auto-authenticate API clients.
# DEV_AUTH_BYPASS=true
# Comma-separated native callback origins. Expo's exp:// origin is trusted only
# outside production.
KESTREL_ONE_MOBILE_TRUSTED_ORIGINS=kestrelone://
# Enable only after EAS push credentials and enhanced push security are ready.
KESTREL_ONE_EXPO_PUSH_ENABLED=false
# KESTREL_ONE_EXPO_ACCESS_TOKEN=

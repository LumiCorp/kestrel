{
  "name": "@kestrel/kestrel-one",
  "version": "0.5.1",
  "private": true,
  "description": "Kestrel One application platform with auth, chat, and knowledge-agent capabilities",
  "scripts": {
    "clean": "rm -rf .next tsconfig.tsbuildinfo",
    "check:kestrel-boundary": "node --import tsx scripts/check-kestrel-boundary.ts",
    "dev": "WATCHPACK_POLLING=true CHOKIDAR_USEPOLLING=true next dev --port 43103 --webpack",
    "dev:all": "./scripts/dev-all.sh",
    "dev:secure": "WATCHPACK_POLLING=true CHOKIDAR_USEPOLLING=true next dev --port 43103 --webpack --experimental-https",
    "build": "tsx lib/db/migrate.ts && next build",
    "start": "next start --port 43103",
    "format": "ultracite fix",
    "lint": "ultracite check",
    "lint:fix": "ultracite fix",
    "lint:check": "ultracite check",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx lib/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:pull": "drizzle-kit pull",
    "db:check": "drizzle-kit check",
    "db:up": "drizzle-kit up",
    "db:reset": "docker compose down -v",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f postgres redis minio",
    "infra:ps": "docker compose ps postgres redis minio",
    "infra:reset": "docker compose down -v && docker compose up -d",
    "smoke:local": "./scripts/smoke-local.sh",
    "create-dev-admin": "tsx scripts/create-dev-admin.ts",
    "bootstrap": "tsx scripts/bootstrap.ts",
    "generate-secret": "tsx scripts/generate-secret.ts",
    "gateway-credentials:migrate": "tsx scripts/migrate-gateway-credentials.ts",
    "setup": "tsx scripts/setup.ts",
    "fixtures:rag": "pnpm exec tsx scripts/generate-rag-fixtures.ts",
    "test:knowledge-rag:unit": "pnpm exec tsx --test tests/fixtures/knowledge-rag/fixture-corpus.test.ts lib/knowledge/documents/shared.test.ts lib/knowledge/documents/retrieval.test.ts",
    "test:knowledge-page:unit": "pnpm exec tsx --test app/knowledge/knowledge-explorer.test.ts",
    "test:knowledge-rag:e2e": "export PLAYWRIGHT=True && pnpm exec playwright test tests/e2e/knowledge-rag.test.ts",
    "test:e2e": "export PLAYWRIGHT=True && pnpm exec playwright test",
    "test:unit": "pnpm run check:kestrel-boundary && node --import tsx --test lib/**/*.test.ts app/**/*.test.ts",
    "test": "pnpm run test:unit"
  },
